---
const { url, title, pubDate } = Astro.props;

const date = new Date(pubDate);
const result = date.toDateString();
---
<style>
    .blog-item {
        list-style: none;
        height: 100%;
        cursor: pointer;
    }

    .blog-link {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        height: 100%;
        padding: 1rem;
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 0.75rem;
        background-color: #ffffff;
        color: inherit;
        text-decoration: none;
        transition: background-color 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
    }

    .blog-item:hover .blog-link,
    .blog-item:focus-within .blog-link {
        background-color: #f8fbff;
        border-color: rgba(0, 83, 159, 0.2);
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
        transform: translateY(-1px);
    }

    .blog-link:focus-visible {
        outline: 2px solid #00539f;
        outline-offset: 3px;
    }

    .blog-icon {
        flex-shrink: 0;
        margin-top: 0.15rem;
        font-size: 1.125rem;
        color: #00539f;
    }

    .blog-content {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .blog-title {
        margin: 0;
        color: #111827;
        font-weight: 600;
        line-height: 1.4;
        overflow-wrap: anywhere;
        word-break: break-word;
        white-space: normal;
    }

    .date-wrapper {
        color: rgb(85, 85, 85);
        font-size: 0.875rem;
        line-height: 1.4;
    }
</style>

<li class="blog-item">
    <a href={url} class="blog-link">
        <i class="bx bx-chevron-right blog-icon" aria-hidden="true"></i>
        <div class="blog-content">
            <span class="blog-title">{title}</span>
            <time class="date-wrapper" datetime={date.toISOString()}>{result}</time>
        </div>
    </a>
</li>